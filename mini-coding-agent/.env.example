# Model API configuration
MINI_AGENT_MODEL=qwen3.5:4b
MINI_AGENT_BASE_URL=http://localhost:11434/v1
MINI_AGENT_API_KEY=

# Also accepts standard OpenAI env vars as fallback
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Agent behavior
MINI_AGENT_APPROVAL=ask
MINI_AGENT_MAX_STEPS=6
MINI_AGENT_MAX_NEW_TOKENS=512
MINI_AGENT_TEMPERATURE=0.2
MINI_AGENT_TOP_P=0.9
MINI_AGENT_TIMEOUT=300
MINI_AGENT_CWD=.
