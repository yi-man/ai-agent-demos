# Model configuration (all are read automatically from this file when it lives in the package root)
OPENAI_API_KEY=sk-your-key-here
# Required for OpenAI-compatible vendors (e.g. Volcengine Ark); defaults to https://api.openai.com/v1 if unset
OPENAI_BASE_URL=https://api.openai.com/v1

# Default model when you do not pass -m (first non-empty wins)
# MSWEA_MODEL_NAME=gpt-4o
# OPENAI_MODEL_NAME=gpt-4o
